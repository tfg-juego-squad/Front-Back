[sub_resource type="GDScript" id="GDScript_nivel"]
script/source = "extends Node2D

@onready var menu_pausa = $MenuPausa

func _input(event):
	if event.is_action_pressed(\"ui_cancel\"): # ESC por defecto
		menu_pausa.toggle_pausa()
"

